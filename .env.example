# Genesis Manthan — API Keys & Secrets (EXAMPLE)
# Copy this to .env and fill in your keys.
# .env is git-ignored. Never commit actual keys.
#
# ── Data Generation ───────────────────────────────────────────
# Google Gemini (primary) — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (fallback) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (fallback) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── HuggingFace ────────────────────────────────────────────────
# Get at https://huggingface.co/settings/tokens  (write access required)
HF_TOKEN=your_huggingface_token_here

# ── Kaggle (optional for local use) ───────────────────────────
# In Kaggle notebooks these are read via UserSecretsClient, not this file.
# For local Kaggle CLI usage only:
KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_key_here
